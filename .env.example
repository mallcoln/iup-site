# Variáveis de ambiente do projeto IUP. Copie para .env.local e preencha.
# NUNCA commitar valores reais — .env.local é ignorado pelo git.

# Meta Pixel ID / Dataset ID (público — usado no navegador)
NEXT_PUBLIC_META_PIXEL_ID=

# Token da Conversions API do Meta (SECRETO — apenas server-side)
META_CAPI_TOKEN=
